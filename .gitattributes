###############################################################################
# Normalize line endings
###############################################################################
* text=auto

###############################################################################
# Go source files
###############################################################################
*.go text eol=lf

###############################################################################
# Shell / config files
###############################################################################
*.sh text eol=lf
*.env text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

###############################################################################
# Windows scripts
###############################################################################
*.bat text eol=crlf
*.cmd text eol=crlf

###############################################################################
# Markdown / docs
###############################################################################
*.md text eol=lf

###############################################################################
# Binary files (no diff)
###############################################################################
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

###############################################################################
# Swagger generated files
###############################################################################
docs/swagger.json text
docs/swagger.yaml text